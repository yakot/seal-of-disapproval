<div class="block w-full md:w-64 flex-none bg-base-100 border-r border-base-200 min-h-screen">
  <menu-active>
    <div class="px-4 py-4">
      <a href="<%= '/' %>" class="btn btn-ghost btn-sm gap-2 pl-0 hover:bg-transparent text-base-content/70 hover:text-base-content">
        <%= svg_icon('arrow_left', class: 'w-4 h-4 stroke-2') %>
        <span><%= t('back_to_home') %></span>
      </a>
      <h2 class="text-2xl font-bold mt-4 mb-6 px-2"><%= t('settings') %></h2>
    </div>

    <ul id="account_settings_menu" class="menu w-full px-2 space-y-6">
      <!-- Account Group -->
      <li>
        <h3 class="menu-title text-xs font-bold uppercase tracking-wider text-base-content/50 mb-2 px-4"><%= t('account') %></h3>
        <ul class="space-y-1">
          <li>
            <%= link_to settings_profile_index_path, class: 'group flex items-center px-4 py-2 text-sm font-medium rounded-md hover:bg-base-200 hover:text-primary transition-colors' do %>
              <%= svg_icon('user', class: 'w-5 h-5 mr-3 text-base-content/50 group-hover:text-primary') %>
              <%= t('profile') %>
            <% end %>
          </li>
          <li>
            <%= link_to settings_account_path, class: 'group flex items-center px-4 py-2 text-sm font-medium rounded-md hover:bg-base-200 hover:text-primary transition-colors' do %>
              <%= svg_icon('building', class: 'w-5 h-5 mr-3 text-base-content/50 group-hover:text-primary') %>
              <%= t('account') %>
            <% end %>
          </li>
          <li>
            <%= link_to settings_billing_index_path, class: 'group flex items-center px-4 py-2 text-sm font-medium rounded-md hover:bg-base-200 hover:text-primary transition-colors' do %>
              <%= svg_icon('credit_card', class: 'w-5 h-5 mr-3 text-base-content/50 group-hover:text-primary') %>
              <%= t('billing') %>
            <% end %>
          </li>
          <% if can?(:read, User) %>
            <li>
              <% if can?(:access, :settings_users) %>
                <%= link_to settings_users_path, class: 'group flex items-center px-4 py-2 text-sm font-medium rounded-md hover:bg-base-200 hover:text-primary transition-colors' do %>
                  <%= svg_icon('users', class: 'w-5 h-5 mr-3 text-base-content/50 group-hover:text-primary') %>
                  <%= t('users') %>
                <% end %>
              <% else %>
                <%= link_to settings_billing_index_url, class: 'group flex items-center justify-between px-4 py-2 text-sm font-medium rounded-md hover:bg-base-200 hover:text-primary transition-colors' do %>
                  <div class="flex items-center">
                    <%= svg_icon('users', class: 'w-5 h-5 mr-3 text-base-content/50 group-hover:text-primary') %>
                    <%= t('users') %>
                  </div>
                  <span class="badge badge-sm badge-pro ml-auto">Pro</span>
                <% end %>
              <% end %>
            </li>
          <% end %>
        </ul>
      </li>

      <!-- Signing and Sending Group -->
      <li>
        <h3 class="menu-title text-xs font-bold uppercase tracking-wider text-base-content/50 mb-2 px-4"><%= t('signing_and_sending') %></h3>
        <ul class="space-y-1">
          <% if can?(:read, EncryptedConfig.new(key: EncryptedConfig::ESIGN_CERTS_KEY, account: current_account)) %>
            <li>
              <% if can?(:access, :settings_esign) %>
                <%= link_to settings_esign_path, class: 'group flex items-center px-4 py-2 text-sm font-medium rounded-md hover:bg-base-200 hover:text-primary transition-colors' do %>
                  <%= svg_icon('pencil', class: 'w-5 h-5 mr-3 text-base-content/50 group-hover:text-primary') %>
                  <%= t('e_signature') %>
                <% end %>
              <% else %>
                <%= link_to settings_billing_index_url, class: 'group flex items-center justify-between px-4 py-2 text-sm font-medium rounded-md hover:bg-base-200 hover:text-primary transition-colors' do %>
                  <div class="flex items-center">
                    <%= svg_icon('pencil', class: 'w-5 h-5 mr-3 text-base-content/50 group-hover:text-primary') %>
                    <%= t('e_signature') %>
                  </div>
                  <span class="badge badge-sm badge-pro ml-auto">Pro</span>
                <% end %>
              <% end %>
            </li>
          <% end %>

          <% if can?(:read, AccountConfig) %>
            <li>
              <% if can?(:access, :settings_personalization) %>
                <%= link_to settings_personalization_path, class: 'group flex items-center px-4 py-2 text-sm font-medium rounded-md hover:bg-base-200 hover:text-primary transition-colors' do %>
                  <%= svg_icon('adjustments', class: 'w-5 h-5 mr-3 text-base-content/50 group-hover:text-primary') %>
                  <%= t('personalization') %>
                <% end %>
              <% else %>
                <%= link_to settings_billing_index_url, class: 'group flex items-center justify-between px-4 py-2 text-sm font-medium rounded-md hover:bg-base-200 hover:text-primary transition-colors' do %>
                  <div class="flex items-center">
                    <%= svg_icon('adjustments', class: 'w-5 h-5 mr-3 text-base-content/50 group-hover:text-primary') %>
                    <%= t('personalization') %>
                  </div>
                  <span class="badge badge-sm badge-pro ml-auto">Pro</span>
                <% end %>
              <% end %>
            </li>
          <% end %>

          <% if can?(:read, AccountConfig) %>
            <li>
              <% if can?(:access, :settings_notifications) %>
                <%= link_to settings_notifications_path, class: 'group flex items-center px-4 py-2 text-sm font-medium rounded-md hover:bg-base-200 hover:text-primary transition-colors' do %>
                  <%= svg_icon('mail', class: 'w-5 h-5 mr-3 text-base-content/50 group-hover:text-primary') %>
                  <%= t('notifications') %>
                <% end %>
              <% else %>
                <%= link_to settings_billing_index_url, class: 'group flex items-center justify-between px-4 py-2 text-sm font-medium rounded-md hover:bg-base-200 hover:text-primary transition-colors' do %>
                  <div class="flex items-center">
                    <%= svg_icon('mail', class: 'w-5 h-5 mr-3 text-base-content/50 group-hover:text-primary') %>
                    <%= t('notifications') %>
                  </div>
                  <span class="badge badge-sm badge-pro ml-auto">Pro</span>
                <% end %>
              <% end %>
            </li>
          <% end %>

           <% if can?(:read, EncryptedConfig.new(key: EncryptedConfig::EMAIL_SMTP_KEY, account: current_account)) && ENV['SMTP_ADDRESS'].blank? && true_user == current_user && false %>
            <li>
              <% if can?(:access, :settings_email) %>
                <%= link_to settings_email_index_path, class: 'group flex items-center px-4 py-2 text-sm font-medium rounded-md hover:bg-base-200 hover:text-primary transition-colors' do %>
                  <%= svg_icon('mail_opened', class: 'w-5 h-5 mr-3 text-base-content/50 group-hover:text-primary') %>
                  <%= t('email') %>
                <% end %>
              <% else %>
                <%= link_to settings_billing_index_url, class: 'group flex items-center justify-between px-4 py-2 text-sm font-medium rounded-md hover:bg-base-200 hover:text-primary transition-colors' do %>
                  <div class="flex items-center">
                    <%= svg_icon('mail_opened', class: 'w-5 h-5 mr-3 text-base-content/50 group-hover:text-primary') %>
                    <%= t('email') %>
                  </div>
                  <span class="badge badge-sm badge-pro ml-auto">Pro</span>
                <% end %>
              <% end %>
            </li>
          <% end %>
        </ul>
      </li>

      <!-- Integrations Group -->
      <li>
        <h3 class="menu-title text-xs font-bold uppercase tracking-wider text-base-content/50 mb-2 px-4"><%= t('integrations') %></h3>
        <ul class="space-y-1">
          <% if can?(:read, AccessToken) || Docuseal.feature_restricted?('api') %>
            <li>
              <% if can?(:read, AccessToken) %>
                <%= link_to settings_api_index_path, class: 'group flex items-center px-4 py-2 text-sm font-medium rounded-md hover:bg-base-200 hover:text-primary transition-colors' do %>
                  <%= svg_icon('code', class: 'w-5 h-5 mr-3 text-base-content/50 group-hover:text-primary') %>
                  <span>API</span>
                <% end %>
              <% else %>
                <%= link_to settings_billing_index_url, class: 'group flex items-center justify-between px-4 py-2 text-sm font-medium rounded-md hover:bg-base-200 hover:text-primary transition-colors' do %>
                  <div class="flex items-center">
                    <%= svg_icon('code', class: 'w-5 h-5 mr-3 text-base-content/50 group-hover:text-primary') %>
                    <span>API</span>
                  </div>
                  <span class="badge badge-sm badge-pro ml-auto">Pro</span>
                <% end %>
              <% end %>
            </li>
          <% end %>

          <% if can?(:read, WebhookUrl) || Docuseal.feature_restricted?('webhooks') %>
            <li>
              <% if can?(:read, WebhookUrl) %>
                <%= link_to settings_webhooks_path, class: 'group flex items-center px-4 py-2 text-sm font-medium rounded-md hover:bg-base-200 hover:text-primary transition-colors' do %>
                  <%= svg_icon('world', class: 'w-5 h-5 mr-3 text-base-content/50 group-hover:text-primary') %>
                  <span>Webhooks</span>
                <% end %>
              <% else %>
                <%= link_to settings_billing_index_url, class: 'group flex items-center justify-between px-4 py-2 text-sm font-medium rounded-md hover:bg-base-200 hover:text-primary transition-colors' do %>
                  <div class="flex items-center">
                    <%= svg_icon('world', class: 'w-5 h-5 mr-3 text-base-content/50 group-hover:text-primary') %>
                    <span>Webhooks</span>
                  </div>
                  <span class="badge badge-sm badge-pro ml-auto">Pro</span>
                <% end %>
              <% end %>
            </li>
          <% end %>

          <% if !Docuseal.demo? && can?(:manage, EncryptedConfig) && (current_user == true_user || current_account.testing?) %>
            <% if can?(:read, EncryptedConfig.new(key: 'saml_configs', account: current_account)) || Docuseal.feature_restricted?('sso') %>
              <li>
                <% if can?(:manage, :saml_sso) %>
                  <%= link_to settings_sso_index_path, class: 'group flex items-center px-4 py-2 text-sm font-medium rounded-md hover:bg-base-200 hover:text-primary transition-colors' do %>
                    <%= svg_icon('lock', class: 'w-5 h-5 mr-3 text-base-content/50 group-hover:text-primary') %>
                    <span>SSO</span>
                  <% end %>
                <% else %>
                  <%= link_to settings_billing_index_url, class: 'group flex items-center justify-between px-4 py-2 text-sm font-medium rounded-md hover:bg-base-200 hover:text-primary transition-colors' do %>
                    <div class="flex items-center">
                      <%= svg_icon('lock', class: 'w-5 h-5 mr-3 text-base-content/50 group-hover:text-primary') %>
                      <span>SSO</span>
                    </div>
                    <span class="badge badge-sm badge-pro ml-auto">Pro</span>
                  <% end %>
                <% end %>
              </li>
            <% end %>
            <%= render 'shared/settings_nav_extra2' %>
          <% end %>
          <li>
            <%= link_to self_host_index_path, class: 'group flex items-center px-4 py-2 text-sm font-medium rounded-md hover:bg-base-200 hover:text-primary transition-colors' do %>
              <%= svg_icon('cloud_upload', class: 'w-5 h-5 mr-3 text-base-content/50 group-hover:text-primary') %>
              <span>Self Host</span>
            <% end %>
          </li>
        </ul>
      </li>
      <%= render 'shared/settings_nav_extra' %>
    </ul>
  </menu-active>
</div>
