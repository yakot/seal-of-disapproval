<a href="<%= folder_path(folder) %>" class="flex items-center p-4 rounded-xl border border-base-300 bg-base-100 hover:border-primary hover:shadow-md transition-all duration-200 group" data-targets="dashboard-dropzone.folderCards" data-full-name="<%= folder.full_name %>">
  <%= svg_icon('folder', class: 'w-10 h-10 text-accent mr-3 flex-shrink-0 fill-current') %>
  <div class="min-w-0 flex-1">
    <div class="font-semibold text-base truncate group-hover:text-primary transition-colors">
      <%= folder.name %>
    </div>
    <div class="text-xs text-base-content/60 truncate">
      <%= t('folder', default: 'Folder') %>
    </div>
  </div>
</a>
