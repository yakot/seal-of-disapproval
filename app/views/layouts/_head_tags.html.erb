<title>
  <%= content_for(:html_title) || (signed_in? ? 'GoSign' : 'GoSign | The free DocuSign Alternative') %>
</title>
<%= render 'shared/meta' %>
<script nonce="<%= content_security_policy_nonce %>">
  (function () {
    var light = 'docuseal';
    var dark = 'docuseal_dark';
    var html = document.documentElement;
    var theme = html.getAttribute('data-theme') || light;
    var isDark = theme === dark;
    html.setAttribute('data-theme', isDark ? dark : light);
    html.classList.toggle('dark', isDark);
    var metaTheme = document.querySelector('meta[name="theme-color"]');
    if (metaTheme) metaTheme.setAttribute('content', isDark ? '#0f172a' : '#faf7f5');
  })();
</script>
