<div class="flex min-h-screen items-center justify-center px-4 py-12 bg-gray-50/50">
  <div class="w-full max-w-lg">
    <div class="overflow-hidden rounded-2xl bg-white shadow-2xl ring-1 ring-gray-900/5">
      <!-- Status Header -->
      <div class="bg-gradient-to-br from-gray-500 to-slate-600 px-8 py-8 text-center">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-white/20 backdrop-blur-sm mb-4">
          <%= svg_icon('archive', class: 'w-10 h-10 text-white') %>
        </div>
        <h1 class="text-2xl font-bold text-white tracking-tight">
          <%= t('form_has_been_archived') %>
        </h1>
      </div>

      <!-- Document Info -->
      <div class="px-8 py-6">
        <div class="flex items-center rounded-xl border border-gray-100 bg-gray-50/80 p-4">
          <div class="mr-4 flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-lg bg-gray-100">
            <%= svg_icon('writing_sign', class: 'w-6 h-6 text-gray-600') %>
          </div>
          <div dir="auto" class="min-w-0">
            <p class="text-base font-semibold text-gray-900 truncate"><%= @submitter.submission.name || @submitter.submission.template.name %></p>
            <p class="text-sm text-gray-500 mt-0.5"><%= t('form_has_been_deleted_by_html', name: @submitter.account.name) %></p>
          </div>
        </div>
      </div>

      <!-- Footer -->
      <div class="border-t border-gray-100 bg-gray-50/50 px-8 py-4">
        <div class="flex items-center justify-center gap-2 text-xs text-gray-400">
          <%= svg_icon('shield_check', class: 'w-4 h-4') %>
          <span>Secured by GoSign</span>
        </div>
      </div>
    </div>
  </div>
</div>
