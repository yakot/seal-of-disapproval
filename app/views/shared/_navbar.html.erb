<div class="w-full bg-base-100 border-b border-base-300 mb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16">
      <div class="flex items-center">
        <a href="<%= signed_in? ? dashboard_index_path : root_path %>" class="flex-shrink-0 flex items-center space-x-2">
          <%= render 'shared/title' %>
        </a>
        <span class="hidden sm:inline ml-4">
          <%= render 'shared/github' if request.path.starts_with?('/settings') %>
        </span>
      </div>
      <% if signed_in? && !Docuseal.demo? %>
        <div class="hidden md:flex items-center space-x-6">
          <%= render 'shared/navbar_buttons' %>
          <%= link_to t('settings'), settings_profile_index_path, class: 'text-sm font-medium text-gray-600 hover:text-gray-900', id: 'account_settings_button' %>
        </div>
      <% end %>
      <div class="flex items-center space-x-4">
        <% if signed_in? %>
          <% if Docuseal.demo? %>
            <a href="https://docuseal.com/sign_up" class="btn btn-primary btn-sm text-white px-4">
              <%= t('sign_up') %>
            </a>
            <span class="hidden sm:inline">
              <%= render 'shared/github_button' %>
            </span>
          <% else %>
            <div class="hidden md:flex items-center space-x-2">
              <%= link_to self_host_index_path, class: 'btn btn-outline btn-sm' do %>
                Self Host
              <% end %>
              <% unless current_account.subscribed? %>
                <%= link_to settings_billing_index_path, class: 'btn btn-primary btn-sm text-white' do %>
                  Upgrade
                <% end %>
              <% end %>
            </div>
          <% end %>
          <div class="dropdown dropdown-end">
            <label tabindex="0" class="btn btn-ghost btn-circle avatar placeholder">
              <div class="bg-neutral text-neutral-content rounded-full w-8">
                <span class="text-xs"><%= current_user.initials %></span>
              </div>
            </label>
            <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-base-100 rounded-box w-52 border border-base-200">
              <li>
                <%= link_to settings_profile_index_path, class: 'flex items-center py-2' do %>
                  <%= svg_icon('adjustments', class: 'w-4 h-4 mr-2') %>
                  <%= t('profile') %>
                <% end %>
              </li>
              <% if can?(:read, EncryptedConfig.new(key: EncryptedConfig::ESIGN_CERTS_KEY, account: current_account)) %>
                <li>
                  <%= link_to settings_esign_path, class: 'flex items-center py-2' do %>
                    <%= svg_icon('zoom_check', class: 'w-4 h-4 mr-2') %>
                    <%= t('verify_pdf') %>
                  <% end %>
                </li>
              <% end %>
              <% if (can?(:manage, EncryptedConfig) && current_user == true_user) || (current_user != true_user && current_account.testing?) %>
                <li>
                  <%= form_for '', url: testing_account_path, method: current_account.testing? ? :delete : :get, html: { class: 'w-full' } do |f| %>
                    <label class="flex items-center justify-between w-full cursor-pointer" for="testing_toggle">
                      <span class="mr-2"><%= t('test_mode') %></span>
                      <submit-form data-on="change" class="flex">
                        <%= f.check_box :testing_toggle, class: 'toggle toggle-sm toggle-primary', checked: current_account.testing? %>
                      </submit-form>
                    </label>
                  <% end %>
                </li>
              <% end %>
              <li>
                <button type="button" class="flex items-center justify-between w-full py-2 text-left gap-2" data-theme-toggle aria-label="Toggle dark mode">
                  <span class="flex items-center min-w-0">
                    <%= svg_icon('device_desktop', class: 'w-4 h-4 mr-2 shrink-0') %>
                    <span class="truncate" data-theme-toggle-label>Dark mode</span>
                  </span>
                  <input type="checkbox" class="toggle toggle-sm toggle-primary pointer-events-none" data-theme-toggle-input>
                </button>
              </li>
              <div class="divider my-1"></div>
              <li>
                <%= button_to destroy_user_session_path, method: :delete, data: { turbo: false }, class: 'flex items-center py-2 text-red-600 hover:bg-red-50' do %>
                  <%= svg_icon('logout', class: 'w-4 h-4 mr-2') %>
                  <%= t('sign_out') %>
                <% end %>
              </li>
            </ul>
          </div>
        <% else %>
          <div class="flex items-center space-x-4">
            <% if request.path != new_user_session_path && request.path != setup_index_path %>
              <%= link_to new_user_session_path({ lang: params[:lang] }.compact_blank), class: 'text-sm font-medium text-gray-600 hover:text-gray-900' do %>
                <%= t('sign_in') %>
              <% end %>
            <% end %>
            <% if Docuseal.multitenant? && !request.path.in?([registration_path, new_registration_path]) %>
              <%= link_to registration_path({ lang: params[:lang] }.compact_blank), class: 'btn btn-primary btn-sm text-white' do %>
                <%= t('create_free_account') %>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
