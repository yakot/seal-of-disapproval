<div class="flex flex-col space-y-4 mb-6">
  <div>
    <%= link_to templates_path, class: "inline-flex items-center text-sm text-base-content/60 hover:text-primary transition-colors mb-2" do %>
      <%= svg_icon('arrow_left', class: 'w-4 h-4 mr-1') %>
      <%= t('back_to_templates', default: 'Back to Templates') %>
    <% end %>
  </div>

  <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
    <div class="flex-1 min-w-0">
      <div class="flex items-start gap-3">
        <div class="p-3 bg-primary/10 rounded-xl hidden md:block">
          <%= svg_icon('file_text', class: 'w-8 h-8 text-primary') %>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1">
            <h1 class="text-2xl md:text-3xl font-bold text-base-content truncate" title="<%= template.name %>">
              <% template.name.split(/(_)/).each do |item| %><%= item %><wbr><% end %>
            </h1>
            <% if template.archived_at? %>
              <span class="badge badge-warning badge-outline"><%= t('archived') %></span>
            <% end %>
            <%= render 'templates/access_icon', template: @template %>
          </div>
          
          <div class="flex items-center gap-4 text-sm text-base-content/60">
            <% if @template.account_id == current_account.id %>
              <a href="<%= folder_path(@template.folder) %>" class="flex items-center hover:text-primary transition-colors group">
                <%= svg_icon('folder', class: 'w-4 h-4 mr-1.5 group-hover:text-primary') %>
                <span><%= @template.folder.full_name %></span>
              </a>
              <% if can?(:update, template) %>
                <a href="<%= edit_template_folder_path(template.id, subfolder: @template.folder.parent_folder.present?) %>" data-turbo-frame="modal" class="p-1 hover:bg-base-200 rounded-full transition-colors text-base-content/40 hover:text-primary" title="<%= t('move') %>">
                  <%= svg_icon('pencil', class: 'w-3 h-3') %>
                </a>
              <% end %>
            <% else %>
              <span class="flex items-center">
                <span class="badge badge-neutral badge-outline badge-sm uppercase"><%= t('shared') %></span>
              </span>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <div class="flex flex-wrap items-center gap-2">
      <% if !template.archived_at? %>
        <div class="join shadow-sm border border-base-300 rounded-lg bg-base-100">
          <% if can?(:update, template) %>
            <%= link_to edit_template_path(template), class: 'btn btn-sm btn-ghost join-item hover:bg-base-200' do %>
              <%= svg_icon('pencil', class: 'w-4 h-4') %>
              <span class="hidden sm:inline"><%= t('edit') %></span>
            <% end %>
            
            <%= link_to template_preferences_path(template), class: 'btn btn-sm btn-ghost join-item hover:bg-base-200', data: { turbo_frame: :modal }, title: t('preferences') do %>
              <%= svg_icon('adjustments_horizontal', class: 'w-4 h-4') %>
            <% end %>
          <% elsif can?(:read, template) %>
             <%= link_to template_preview_path(template), class: 'btn btn-sm btn-ghost join-item hover:bg-base-200' do %>
              <%= svg_icon('eye', class: 'w-4 h-4') %>
              <span class="hidden sm:inline"><%= t('preview') %></span>
            <% end %>
          <% end %>

          <% if can?(:create, current_account.templates.new(author: current_user)) %>
            <%= link_to new_template_clone_path(template), class: 'btn btn-sm btn-ghost join-item hover:bg-base-200', data: { turbo_frame: :modal }, title: t('clone') do %>
              <%= svg_icon('copy', class: 'w-4 h-4') %>
            <% end %>
          <% end %>
        </div>

        <%= link_to template_share_link_path(template), class: 'btn btn-sm btn-primary', data: { turbo_frame: :modal } do %>
          <%= svg_icon('link', class: 'w-4 h-4') %>
          <%= t('link') %>
        <% end %>

        <% if can?(:destroy, template) %>
          <div class="dropdown dropdown-end">
            <div tabindex="0" role="button" class="btn btn-sm btn-square btn-ghost">
              <%= svg_icon('dots_vertical', class: 'w-5 h-5') %>
            </div>
            <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow-lg bg-base-100 rounded-box w-52 border border-base-200">
              <li>
                <%= button_to template_path(template), method: :delete, class: 'text-error hover:bg-error/10', data: { turbo_confirm: t('are_you_sure_') } do %>
                  <%= svg_icon('archive', class: 'w-4 h-4') %>
                  <%= t('archive') %>
                <% end %>
              </li>
            </ul>
          </div>
        <% end %>

      <% else %>
        <%# Archived State Actions %>
        <% if can?(:create, template) %>
          <%= button_to template_restore_index_path(template), class: 'btn btn-sm btn-outline gap-2' do %>
            <%= svg_icon('rotate', class: 'w-4 h-4') %>
            <%= t('restore') %>
          <% end %>
        <% end %>
        
        <% if can?(:destroy, template) %>
          <%= button_to template_path(template), method: :delete, class: 'btn btn-sm btn-error btn-outline gap-2', data: { turbo_confirm: t('template_deletion_is_irreversible_and_will_permanently_remove_all_associated_signed_documents_with_it_are_you_sure_') }, params: { permanently: true } do %>
            <%= svg_icon('trash', class: 'w-4 h-4') %>
            <%= t('delete_permanently', default: 'Delete Permanently') %>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
