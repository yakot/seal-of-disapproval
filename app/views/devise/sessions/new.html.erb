<%= content_for(:canonical_url, new_user_session_url) %>
<div class="flex min-h-[80vh] items-center justify-center py-12 sm:px-6 lg:px-8">
  <div class="flex w-full max-w-[1000px] overflow-hidden rounded-2xl bg-white shadow-2xl ring-1 ring-gray-900/5">
    
    <!-- Left Side: Branding (Hidden on mobile) -->
    <div class="hidden w-1/2 bg-primary p-12 lg:flex flex-col justify-between relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-primary to-blue-900 opacity-90"></div>
      <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMSIgY3k9IjEiIHI9IjEiIGZpbGw9InJnYmEoMjU1LDI1NSwyNTUsMC4xKSIvPjwvc3ZnPg==')] opacity-30"></div>
      
      <div class="relative z-10">
        <h2 class="text-3xl font-bold text-white mb-6">GoSign</h2>
        <div class="space-y-4">
          <p class="text-blue-100 text-lg leading-relaxed">
            Secure, legally binding, and effortless document signing for the modern enterprise.
          </p>
          <div class="flex items-center space-x-2 text-blue-200 text-sm mt-8">
            <%= svg_icon('shield_check', class: 'w-5 h-5') %>
            <span>Bank-grade security</span>
          </div>
          <div class="flex items-center space-x-2 text-blue-200 text-sm">
            <%= svg_icon('world', class: 'w-5 h-5') %>
            <span>Global compliance</span>
          </div>
        </div>
      </div>

      <div class="relative z-10 text-blue-200 text-sm">
        &copy; <%= Date.today.year %> GoSign. All rights reserved.
      </div>
    </div>

    <!-- Right Side: Login Form -->
    <div class="w-full lg:w-1/2 p-8 sm:p-12">
      <%= render 'devise/shared/select_server' if Docuseal.multitenant? %>
      
      <div class="mb-8">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900"><%= t('sign_in') %></h2>
        <p class="mt-2 text-sm text-gray-600">
          New to GoSign? 
          <a href="<%= new_registration_path %>" class="font-medium text-primary hover:text-primary/80 transition-colors">
            Create an account
          </a>
        </p>
      </div>

      <%= form_for(resource, as: resource_name, html: { class: 'space-y-6' }, data: { turbo: params[:redir].blank? }, url: session_path(resource_name)) do |f| %>
        <%= render 'hidden_fields' %>
        
        <div class="space-y-5">
          <div class="form-control">
            <%= f.label :email, t(:email), class: 'block text-sm font-semibold text-gray-700 mb-1.5' %>
            <%= f.email_field :email, autofocus: true, autocomplete: 'email', class: 'block w-full rounded-lg border-gray-300 px-4 py-3 text-gray-900 shadow-sm focus:border-primary focus:ring-primary sm:text-sm bg-gray-50/50 hover:bg-white transition-colors', placeholder: 'name@company.com' %>
          </div>

          <div class="form-control">
            <div class="flex items-center justify-between mb-1.5">
              <%= f.label :password, t(:password), class: 'block text-sm font-semibold text-gray-700' %>
              <a href="<%= new_password_path(resource_name) %>" class="text-sm font-medium text-primary hover:text-primary/80">
                Forgot password?
              </a>
            </div>
            <%= f.password_field :password, autocomplete: 'current-password', class: 'block w-full rounded-lg border-gray-300 px-4 py-3 text-gray-900 shadow-sm focus:border-primary focus:ring-primary sm:text-sm bg-gray-50/50 hover:bg-white transition-colors', placeholder: '••••••••' %>
          </div>
        </div>

        <div>
          <%= f.button class: 'flex w-full justify-center rounded-lg bg-primary px-4 py-3 text-sm font-bold text-white shadow-lg shadow-primary/30 hover:bg-primary/90 hover:shadow-primary/40 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary transition-all transform active:scale-[0.98]' do %>
            <%= t(:sign_in) %>
          <% end %>
        </div>
      <% end %>

      <% if devise_mapping.omniauthable? %>
        <div class="mt-8">
          <div class="relative">
            <div class="absolute inset-0 flex items-center">
              <div class="w-full border-t border-gray-200"></div>
            </div>
            <div class="relative flex justify-center text-sm">
              <span class="bg-white px-4 text-gray-500 font-medium">Or continue with</span>
            </div>
          </div>

          <div class="mt-6 grid grid-cols-1 gap-3">
            <% if User.omniauth_providers.include?(:google_oauth2) %>
              <%= form_for '', url: user_google_oauth2_omniauth_authorize_path, data: { turbo: false }, method: :post do |f| %>
                <set-timezone data-input-id="state" data-params="true"></set-timezone>
                <%= hidden_field_tag :state, { redir: params[:redir].to_s }.compact_blank.to_query %>
                <%= f.button class: 'flex w-full items-center justify-center gap-3 rounded-lg border border-gray-300 bg-white px-3 py-2.5 text-sm font-semibold text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-200 transition-all' do %>
                  <%= svg_icon('brand_google', class: 'h-5 w-5') %>
                  <span class="text-sm">Google</span>
                <% end %>
              <% end %>
            <% end %>
            
            <% if User.omniauth_providers.include?(:microsoft_graph) %>
              <%= form_for '', url: user_microsoft_graph_omniauth_authorize_path, data: { turbo: false }, method: :post do |f| %>
                <set-timezone data-input-id="state_microsoft" data-params="true"></set-timezone>
                <%= hidden_field_tag :state, { redir: params[:redir].to_s }.compact_blank.to_query, id: 'state_microsoft' %>
                <%= f.button class: 'flex w-full items-center justify-center gap-3 rounded-lg border border-gray-300 bg-white px-3 py-2.5 text-sm font-semibold text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-200 transition-all' do %>
                  <%= svg_icon('brand_microsoft', class: 'h-5 w-5') %>
                  <span class="text-sm">Microsoft</span>
                <% end %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
      
      <% if render('extra_links').present? %>
         <div class="mt-6 text-center">
           <%= render 'extra_links' %>
         </div>
      <% end %>
    </div>
  </div>
</div>
