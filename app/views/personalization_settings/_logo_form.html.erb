<% if current_account.logo.attached? %>
  <div class="card bg-base-100 border border-base-300 mb-4">
    <div class="card-body">
      <div class="flex flex-col items-center">
        <%= image_tag current_account.logo.url, class: 'h-32 object-contain mb-4' %>
        <%= button_to delete_logo_settings_personalization_path, method: :delete, class: 'btn btn-outline btn-error w-full', data: { turbo_confirm: t('are_you_sure_') } do %>
          <%= svg_icon('trash', class: 'w-4 h-4') %>
          <span><%= t('remove') %></span>
        <% end %>
      </div>
    </div>
  </div>
<% else %>
  <%= form_for '', url: upload_logo_settings_personalization_path, method: :post, html: { enctype: 'multipart/form-data' } do %>
    <button type="submit" class="hidden"></button>
    <file-dropzone data-submit-on-upload="true" class="w-full">
      <label for="logo_file_input" class="w-full block h-52 relative bg-base-200 hover:bg-base-200/70 rounded-xl border-2 border-base-300 border-dashed cursor-pointer" data-target="file-dropzone.area">
        <div class="absolute top-0 right-0 left-0 bottom-0 flex items-center justify-center p-4 pointer-events-none">
          <div class="flex flex-col items-center text-center">
            <span data-target="file-dropzone.icon">
              <%= svg_icon('cloud_upload', class: 'w-12 h-12 mb-3') %>
            </span>
            <span data-target="file-dropzone.loading" class="hidden">
              <%= svg_icon('loader', class: 'w-12 h-12 animate-spin mb-3') %>
            </span>
            <div class="text-2xl font-bold mb-2">
              <%= t('upload_logo') %>
            </div>
            <div class="text-base">
              <%= t('click_to_upload_or_drag_and_drop_html') %>
            </div>
          </div>
          <input id="logo_file_input" name="logo" class="hidden" data-action="change:file-dropzone#onSelectFiles" data-target="file-dropzone.input" type="file" accept="image/*">
        </div>
      </label>
    </file-dropzone>
  <% end %>
<% end %>
