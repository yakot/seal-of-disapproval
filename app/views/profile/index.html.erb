<div class="flex flex-wrap md:flex-nowrap h-full bg-base-200/50">
  <%= render 'shared/settings_nav' %>
  
  <div class="flex-grow p-6 md:p-10 overflow-y-auto">
    <div class="max-w-4xl mx-auto space-y-8">
      
      <!-- Header -->
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-3xl font-bold text-base-content"><%= t('profile') %></h1>
          <p class="text-base-content/60 mt-1"><%= t('manage_your_personal_information_and_security') %></p>
        </div>
      </div>

      <!-- Personal Information Card -->
      <div class="card bg-base-100 shadow-sm border border-base-200">
        <div class="card-body p-6">
          <h2 class="card-title text-lg font-bold mb-4 border-b border-base-200 pb-2"><%= t('personal_information') %></h2>
          
          <%= form_for current_user, url: update_contact_settings_profile_index_path, method: :patch, html: { autocomplete: 'off', class: 'space-y-6' } do |f| %>
            <div class="grid md:grid-cols-2 gap-6">
              <div class="form-control w-full">
                <%= f.label :first_name, t('first_name'), class: 'label font-medium' %>
                <%= f.text_field :first_name, required: true, class: 'input input-bordered w-full focus:input-primary', dir: 'auto' %>
              </div>
              <div class="form-control w-full">
                <%= f.label :last_name, t('last_name'), class: 'label font-medium' %>
                <%= f.text_field :last_name, required: false, class: 'input input-bordered w-full focus:input-primary', dir: 'auto' %>
              </div>
            </div>
            
            <div class="form-control w-full">
              <%= f.label :email, t('email'), class: 'label font-medium' %>
              <%= f.email_field :email, autocomplete: 'off', class: 'input input-bordered w-full focus:input-primary' %>
              <% if current_user.try(:pending_reconfirmation?) %>
                <label class="label">
                  <span class="label-text-alt text-warning"><%= t('email_address_is_awaiting_confirmation_follow_the_link_in_the_email_to_confirm', email: f.object.unconfirmed_email) %></span>
                </label>
              <% end %>
            </div>
            
            <div class="card-actions justify-end pt-2">
              <%= f.button button_title(title: t('update'), disabled_with: t('updating')), class: 'btn btn-primary' %>
            </div>
          <% end %>
        </div>
      </div>

      <%= render 'email_configs' %>

      <!-- Signature & Initials Grid -->
      <div class="grid md:grid-cols-2 gap-6">
        <!-- Signature Card -->
        <div class="card bg-base-100 shadow-sm border border-base-200">
          <div class="card-body p-6">
            <h2 class="card-title text-lg font-bold mb-4 border-b border-base-200 pb-2"><%= t('signature') %></h2>
            
            <% signature = UserConfigs.load_signature(current_user) %>
            <div class="min-h-[160px] flex items-center justify-center bg-base-200/30 rounded-lg mb-4 border border-dashed border-base-300 relative group">
              <% if signature %>
                <%= button_to user_signature_path, method: :delete, class: 'btn btn-circle btn-xs btn-error absolute top-2 right-2 opacity-0 group-hover:opacity-100 transition-opacity', title: t('remove') do %>
                  <%= svg_icon('x', class: 'w-4 h-4') %>
                <% end %>
                <img src="<%= signature.url %>" class="max-h-[140px] max-w-full object-contain" width="<%= signature.metadata['width'] %>" height="<%= signature.metadata['height'] %>">
              <% else %>
                <span class="text-base-content/40 text-sm"><%= t('no_signature_set') %></span>
              <% end %>
            </div>
            
            <a href="<%= edit_user_signature_path %>" data-turbo-frame="modal" class="btn btn-outline btn-primary w-full">
              <%= signature ? t('update_signature') : t('create_signature') %>
            </a>
          </div>
        </div>

        <!-- Initials Card -->
        <div class="card bg-base-100 shadow-sm border border-base-200">
          <div class="card-body p-6">
            <h2 class="card-title text-lg font-bold mb-4 border-b border-base-200 pb-2"><%= t('initials') %></h2>
            
            <% initials = UserConfigs.load_initials(current_user) %>
            <div class="min-h-[160px] flex items-center justify-center bg-base-200/30 rounded-lg mb-4 border border-dashed border-base-300 relative group">
              <% if initials %>
                <%= button_to user_initials_path, method: :delete, class: 'btn btn-circle btn-xs btn-error absolute top-2 right-2 opacity-0 group-hover:opacity-100 transition-opacity', title: t('remove') do %>
                  <%= svg_icon('x', class: 'w-4 h-4') %>
                <% end %>
                <img src="<%= initials.url %>" class="max-h-[140px] max-w-full object-contain" width="<%= initials.metadata['width'] %>" height="<%= initials.metadata['height'] %>">
              <% else %>
                <span class="text-base-content/40 text-sm"><%= t('no_initials_set') %></span>
              <% end %>
            </div>
            
            <a href="<%= edit_user_initials_path %>" data-turbo-frame="modal" class="btn btn-outline btn-primary w-full">
              <%= initials ? t('update_initials') : t('create_initials') %>
            </a>
          </div>
        </div>
      </div>

      <% if true_user == current_user && !current_account.testing? %>
        <!-- Security Group -->
        <div class="space-y-6">
          <h2 class="text-xl font-bold text-base-content px-1"><%= t('security') %></h2>
          
          <!-- Password Card -->
          <div class="card bg-base-100 shadow-sm border border-base-200">
            <div class="card-body p-6">
              <h3 class="card-title text-lg font-bold mb-4 border-b border-base-200 pb-2"><%= t('change_password') %></h3>
              
              <%= form_for current_user, url: update_password_settings_profile_index_path, method: :patch, html: { autocomplete: 'off' } do |f| %>
                <div class="form-control w-full mb-4">
                  <%= f.label :password, t('new_password'), class: 'label font-medium' %>
                  <%= f.password_field :password, autocomplete: 'off', class: 'input input-bordered w-full focus:input-primary peer', required: true %>
                </div>
                
                <div class="<%= 'peer-invalid:hidden' if current_user.errors.blank? %> space-y-4">
                  <div class="form-control w-full">
                    <%= f.label :password_confirmation, t('confirm_password'), class: 'label font-medium' %>
                    <%= f.password_field :password_confirmation, autocomplete: 'off', class: 'input input-bordered w-full focus:input-primary' %>
                  </div>
                  
                  <div class="form-control w-full">
                    <%= f.label :current_password, t('current_password'), class: 'label font-medium' %>
                    <%= f.password_field :current_password, autocomplete: 'current-password', class: 'input input-bordered w-full focus:input-primary' %>
                    <% if Accounts.can_send_emails?(current_account) %>
                      <span class="label-text-alt mt-2 text-base-content/60">
                        <%= t('dont_remember_your_current_password_click_here_to_reset_it_html') %>
                      </span>
                    <% end %>
                  </div>
                  
                  <div class="card-actions justify-end pt-2">
                    <%= f.button button_title(title: t('update_password'), disabled_with: t('updating')), class: 'btn btn-primary' %>
                  </div>
                </div>
              <% end %>
              <%= button_to nil, user_send_reset_password_path(current_user), id: 'resend_password_button', method: :put, class: 'hidden', data: { turbo_confirm: t('are_you_sure_') } %>
            </div>
          </div>

          <!-- 2FA Card -->
          <div class="card bg-base-100 shadow-sm border border-base-200">
            <div class="card-body p-6">
              <div class="flex items-center justify-between mb-4 border-b border-base-200 pb-2">
                <h3 class="card-title text-lg font-bold"><%= t('two_factor_authentication') %></h3>
                <% if current_user.otp_required_for_login %>
                  <div class="badge badge-success gap-2">
                    <%= svg_icon('check', class: 'w-3 h-3') %>
                    <%= t('enabled') %>
                  </div>
                <% else %>
                  <div class="badge badge-ghost gap-2">
                    <%= t('disabled') %>
                  </div>
                <% end %>
              </div>
              
              <div class="flex items-center justify-between">
                <p class="text-base-content/70 max-w-lg">
                  <%= t('add_an_extra_layer_of_security_to_your_account_by_requiring_a_verification_code_when_signing_in') %>
                </p>
                
                <% if current_user.otp_required_for_login %>
                  <a href="<%= edit_mfa_setup_path %>" data-turbo-frame="modal" class="btn btn-outline btn-error">
                    <%= svg_icon('lock_open', class: 'w-4 h-4 mr-2') %>
                    <%= t('disable_2fa') %>
                  </a>
                <% else %>
                  <a href="<%= new_mfa_setup_path %>" data-turbo-frame="modal" class="btn btn-primary">
                    <%= svg_icon('lock', class: 'w-4 h-4 mr-2') %>
                    <%= t('set_up_2fa') %>
                  </a>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>