# ============================================
# FoundingSign Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# ============================================

# --------------------------------------------
# Core Application Settings
# --------------------------------------------

# Restrict all features for free users
# RESTRICTED_FEATURES=api,sso,webhooks,email,storage,notifications,esign,personalization,users

# Or pick specific ones
RESTRICTED_FEATURES=api,webhooks,sso

# Leave empty for no restrictions
# RESTRICTED_FEATURES=

# Secret key for encrypting sessions and tokens (required in production)
# Generate with: rails secret
SECRET_KEY_BASE=

# Application URL (used for generating links in emails, etc.)
APP_URL=http://localhost:3000

# Product URL (marketing site, defaults to APP_URL)
PRODUCT_URL=http://localhost:3000

# Force SSL connections (set to any value to enable)
# FORCE_SSL=true

# Enable multi-tenant SaaS mode (allows public sign-ups)
MULTITENANT=true

# Demo mode (for showcasing the app)
# DEMO=true

# --------------------------------------------
# Database Configuration
# --------------------------------------------

# Full database URL (recommended - overrides individual settings below)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/docuseal

# Or use individual settings:
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=docuseal
# DATABASE_USER=postgres
# DATABASE_PASSWORD=postgres

# --------------------------------------------
# Redis Configuration (required for background jobs)
# --------------------------------------------

REDIS_URL=redis://localhost:6379

# Alternative for local development
# LOCAL_REDIS_URL=redis://localhost:6379

# --------------------------------------------
# Email / SMTP Configuration
# --------------------------------------------

# SMTP server address (if blank, email settings can be configured in UI)
# SMTP_ADDRESS=smtp.example.com

# SMTP port (default: 587)
# SMTP_PORT=587

# SMTP authentication method (plain, login, cram_md5)
# SMTP_AUTHENTICATION=plain

# SMTP credentials
# SMTP_USERNAME=your-smtp-username
# SMTP_PASSWORD=your-smtp-password

# SMTP domain (for HELO command)
# SMTP_DOMAIN=example.com

# Default from email address
# SMTP_FROM=noreply@example.com

# Enable STARTTLS (true/false)
# SMTP_ENABLE_STARTTLS=true

# SMTP timeouts in seconds
# SMTP_OPEN_TIMEOUT=5
# SMTP_READ_TIMEOUT=5

# Email host for links in emails (defaults to APP_URL host)
# EMAIL_HOST=app.example.com

# Product email URL (for marketing emails)
# PRODUCT_EMAIL_URL=https://example.com

# Use SMTP in development mode
# USE_SMTP_IN_DEV=true

# --------------------------------------------
# Storage Configuration
# --------------------------------------------

# S3 Storage
# S3_ATTACHMENTS_BUCKET=your-bucket-name

# Google Cloud Storage
# GCS_BUCKET=your-gcs-bucket

# Azure Blob Storage
# AZURE_CONTAINER=your-container-name

# Make ActiveStorage URLs public
# ACTIVE_STORAGE_PUBLIC=true

# Presigned URL expiration (in minutes)
# PRESIGNED_URLS_EXPIRE_MINUTES=60

# --------------------------------------------
# AWS Configuration
# --------------------------------------------

# AWS Secret Manager (for storing secrets)
# AWS_SECRET_MANAGER_ID=your-secret-id

# --------------------------------------------
# Security & SSL
# --------------------------------------------

# Trusted SSL certificates path
# TRUSTED_CERTS=/path/to/certs

# Rails master key (for credentials encryption)
# RAILS_MASTER_KEY=your-master-key

# --------------------------------------------
# Performance & Scaling
# --------------------------------------------

# Web server concurrency (number of worker processes)
# WEB_CONCURRENCY=2

# Auto-detect web concurrency based on CPU
# WEB_CONCURRENCY_AUTO=true

# Rails thread pool size
# RAILS_MAX_THREADS=5
# RAILS_MIN_THREADS=1

# Sidekiq background job threads
# SIDEKIQ_THREADS=5

# Sidekiq web UI basic auth password
# SIDEKIQ_BASIC_AUTH_PASSWORD=your-password

# Enable Ruby YJIT compiler for better performance
# RUBY_YJIT_ENABLE=true

# --------------------------------------------
# PDF & Document Settings
# --------------------------------------------

# PDF rendering format/quality
# PDF_FORMAT=standard

# PDF page quality (for image conversion)
# PAGE_QUALITY=85

# Timestamp server URL (for PDF signatures)
# TIMESERVER_URL=http://timestamp.digicert.com

# --------------------------------------------
# Session & Authentication
# --------------------------------------------

# Remember me duration in days (default: 730 = 2 years)
# SESSION_REMEMBER_DAYS=730

# Google OAuth SSO (get from https://console.cloud.google.com/)
# GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret

# Microsoft OAuth SSO (get from https://portal.azure.com/)
# MICROSOFT_CLIENT_ID=your-application-client-id
# MICROSOFT_CLIENT_SECRET=your-client-secret

# --------------------------------------------
# Intercom (Live Chat Widget)
# --------------------------------------------

# Intercom App ID (enables the Intercom chat widget on all pages)
# INTERCOM_APP_ID=your-intercom-app-id

# --------------------------------------------
# Analytics & Tracking
# --------------------------------------------

# GA4 (Google Analytics 4)
# GA4_MEASUREMENT_ID=your-ga4-measurement-id
# GA4_API_SECRET=your-ga4-api-secret

# Google Ads Conversions
# GOOGLE_ADS_CONVERSION_ID=your-google-ads-conversion-id
# GOOGLE_ADS_CONVERSION_LABEL=your-google-ads-conversion-label

# Meta (Facebook) Pixel & Conversions API
# META_PIXEL_ID=your-meta-pixel-id
# META_DATASET_ID=your-meta-dataset-id
# META_CAPI_ACCESS_TOKEN=your-meta-capi-access-token

# X (Twitter) Pixel
# TWITTER_PIXEL_ID=your-twitter-pixel-id
# TWITTER_PURCHASE_EVENT_ID=your-twitter-purchase-event-id

# Customer.io
# CUSTOMERIO_API_KEY=your-customerio-pipeline-api-key

# --------------------------------------------
# Development & Deployment
# --------------------------------------------

# Rails environment
RAILS_ENV=development

# Application port
# PORT=3000

# Working directory
# WORKDIR=/app

# Run database migrations on startup
# RUN_MIGRATIONS=true

# --------------------------------------------
# Feature Restrictions (Subscription-based)
# --------------------------------------------

# Comma-separated list of features to restrict for free (non-subscribed) users.
# Users without an active Stripe subscription will be redirected to the billing page.
# Leave empty or comment out to allow all features for everyone.
#
# Available options: api, sso, webhooks, email, storage, notifications, esign, personalization, users
# RESTRICTED_FEATURES=api,sso,webhooks,email,storage,notifications,esign,personalization,users
