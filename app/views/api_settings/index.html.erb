<div class="flex flex-wrap md:flex-nowrap h-full bg-base-200/50">
  <%= render 'shared/settings_nav' %>
  
  <div class="flex-grow p-6 md:p-10 overflow-y-auto">
    <div class="max-w-5xl mx-auto space-y-8">
      
      <!-- Header -->
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
          <h1 class="text-3xl font-bold text-base-content">API</h1>
          <p class="text-base-content/60 mt-1"><%= t('manage_api_access_tokens_and_view_documentation') %></p>
        </div>
        <%= render 'shared/test_mode_toggle' %>
      </div>

      <!-- API Token Card -->
      <div class="card bg-base-100 shadow-sm border border-base-200">
        <div class="card-body p-6">
          <h2 class="card-title text-lg font-bold mb-4 border-b border-base-200 pb-2"><%= t('authentication') %></h2>
          
          <div class="form-control w-full">
            <label for="api_key" class="label font-medium">X-Auth-Token</label>
            <div class="flex flex-col md:flex-row gap-4">
              <div class="flex-grow">
                <% token = current_user.access_token.token %>
                <% obscured_token = current_user.access_token.token.sub(token[5..], '*' * token[5..].size) %>
                <% if current_account.testing? %>
                  <div class="join w-full">
                    <masked-input class="block w-full" data-token="<%= token %>">
                      <input id="api_key" type="text" value="<%= obscured_token %>" class="input input-bordered font-mono w-full join-item focus:input-primary" autocomplete="off" readonly>
                    </masked-input>
                    <%= render 'shared/clipboard_copy', icon: 'copy', text: token, class: 'btn btn-square join-item', icon_class: 'w-5 h-5', copy_title: t('copy'), copied_title: t('copied') %>
                  </div>
                <% else %>
                  <a id="access_token_container" href="<%= settings_reveal_access_token_path %>" data-turbo-method="post" class="join w-full group">
                    <input id="api_key" type="text" value="<%= obscured_token %>" class="input input-bordered font-mono w-full join-item cursor-pointer group-hover:input-primary" autocomplete="off" readonly>
                    <div class="btn btn-square join-item">
                      <%= svg_icon('eye', class: 'w-5 h-5') %>
                    </div>
                  </a>
                <% end %>
              </div>
              
              <%= button_to settings_api_index_path, class: 'btn btn-outline btn-warning', data: { turbo_confirm: t('remove_existing_api_token_and_generated_a_new_one_are_you_sure_') } do %>
                <%= svg_icon('reload', class: 'w-5 h-5 mr-2') %>
                <%= t('rotate_token') %>
              <% end %>
            </div>
            <p class="text-xs text-base-content/60 mt-2">
              <%= t('keep_this_token_secure_do_not_share_it_in_publicly_accessible_areas_such_as_github_client_side_code_etc') %>
            </p>
          </div>
        </div>
      </div>

      <!-- Examples Section -->
      <div class="space-y-4">
        <h2 class="text-xl font-bold text-base-content px-1"><%= t('examples') %></h2>
        
        <!-- Multiple Submitters -->
        <div class="collapse collapse-arrow bg-base-100 shadow-sm border border-base-200">
          <input type="checkbox" /> 
          <div class="collapse-title text-lg font-medium flex items-center gap-4">
            <span class="flex-grow"><%= t('request_signature_multiple_submitters_with_default_values') %></span>
            <div class="flex gap-2 text-sm">
              <span class="badge badge-warning font-mono">POST</span>
              <span class="badge badge-ghost font-mono"><%= api_submissions_path %></span>
            </div>
          </div>
          <div class="collapse-content"> 
            <div class="mockup-code bg-[#282c34] text-white overflow-hidden relative mt-2">
              <% text = capture do %>curl --location '<%= api_submissions_url %>' \
       --header 'X-Auth-Token: API_TOKEN' \
       --data-raw '{
         "template_id": <%= current_account.templates.last&.id || 1 %>,
         "submitters": [
           {
             "name": "John Doe",
             "role": "<%= current_account.templates.last ? current_account.templates.last.submitters.first['name'] : 'First Party' %>",
             "email": "<%= current_user.email.sub('@', '+test@') %>",
             "values": {
               "Form Text Field Name": "Default Value"
             }
           },
           { "role": "Second Submitter", "email": "<%= current_user.email.sub('@', '+test2@') %>" }
         ]
       }'<% end.to_str %>
              <div class="absolute top-2 right-2">
                <%= render 'shared/clipboard_copy', icon: 'copy', text:, class: 'btn btn-sm btn-ghost text-white hover:bg-white/10', icon_class: 'w-4 h-4', copy_title: t('copy'), copied_title: t('copied') %>
              </div>
              <pre data-prefix="$"><code class="overflow-x-auto block"><%== HighlightCode.call(text, 'Shell', theme: 'base16.dark') %></code></pre>
            </div>
          </div>
        </div>

        <!-- Single Submitter -->
        <div class="collapse collapse-arrow bg-base-100 shadow-sm border border-base-200">
          <input type="checkbox" /> 
          <div class="collapse-title text-lg font-medium flex items-center gap-4">
            <span class="flex-grow"><%= t('request_signature_single_submitter') %></span>
            <div class="flex gap-2 text-sm">
              <span class="badge badge-warning font-mono">POST</span>
              <span class="badge badge-ghost font-mono"><%= api_submissions_emails_path %></span>
            </div>
          </div>
          <div class="collapse-content"> 
            <div class="mockup-code bg-[#282c34] text-white overflow-hidden relative mt-2">
              <% text = capture do %>curl --location '<%= api_submissions_emails_url %>' \
       --header 'X-Auth-Token: API_TOKEN' \
       --data-raw '{
           "template_id": <%= current_account.templates.last&.id || 1 %>,
           "emails":  "<%= current_user.email.sub('@', '+test@') %>, <%= current_user.email.sub('@', '+test2@') %>"
       }'<% end.to_str %>
              <div class="absolute top-2 right-2">
                <%= render 'shared/clipboard_copy', icon: 'copy', text:, class: 'btn btn-sm btn-ghost text-white hover:bg-white/10', icon_class: 'w-4 h-4', copy_title: t('copy'), copied_title: t('copied') %>
              </div>
              <pre data-prefix="$"><code class="overflow-x-auto block"><%== HighlightCode.call(text, 'Shell', theme: 'base16.dark') %></code></pre>
            </div>
          </div>
        </div>

        <!-- Template Details -->
        <div class="collapse collapse-arrow bg-base-100 shadow-sm border border-base-200">
          <input type="checkbox" /> 
          <div class="collapse-title text-lg font-medium flex items-center gap-4">
            <span class="flex-grow"><%= t('template_details') %></span>
            <div class="flex gap-2 text-sm">
              <span class="badge badge-info font-mono">GET</span>
              <span class="badge badge-ghost font-mono"><%= api_template_path(':id') %></span>
            </div>
          </div>
          <div class="collapse-content"> 
            <div class="mockup-code bg-[#282c34] text-white overflow-hidden relative mt-2">
              <% text = capture do %>curl '<%= api_template_url(current_account.templates&.last || 1) %>' \
       --header 'X-Auth-Token: API_TOKEN'<% end.to_str %>
              <div class="absolute top-2 right-2">
                <%= render 'shared/clipboard_copy', icon: 'copy', text:, class: 'btn btn-sm btn-ghost text-white hover:bg-white/10', icon_class: 'w-4 h-4', copy_title: t('copy'), copied_title: t('copied') %>
              </div>
              <pre data-prefix="$"><code class="overflow-x-auto block"><%== HighlightCode.call(text, 'Shell', theme: 'base16.dark') %></code></pre>
            </div>
          </div>
        </div>
      </div>

      <div class="flex justify-center pt-4">
        <%= link_to '/docs/api', class: 'btn btn-wide btn-primary gap-2', target: '_blank', rel: 'noopener' do %>
          <%= svg_icon('external_link', class: 'w-5 h-5') %>
          <%= t('open_full_api_reference') %>
        <% end %>
      </div>
    </div>
  </div>
</div>