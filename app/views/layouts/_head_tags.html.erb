  <script nonce="<%= content_security_policy_nonce %>">
    window.intercomSettings = {
      api_base: "https://api-iam.intercom.io",
      app_id: "<%= ENV['INTERCOM_APP_ID'] %>",
    };
  </script>
  <script nonce="<%= content_security_policy_nonce %>">
