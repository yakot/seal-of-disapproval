<% status_badges = { 'awaiting' => 'bg-amber-100 text-amber-800', 'sent' => 'bg-blue-100 text-blue-800', 'completed' => 'bg-green-100 text-green-800', 'opened' => 'bg-purple-100 text-purple-800', 'declined' => 'bg-red-100 text-red-800' } %>
<div class="group flex flex-col md:flex-row md:items-center justify-between p-4 hover:bg-gray-50 transition-colors gap-4 first:rounded-t-xl last:rounded-b-xl">
  <div class="flex items-start md:items-center gap-4 min-w-0 flex-1">
    <% unless local_assigns[:with_template] %>
      <div class="flex items-center pt-1 md:pt-0">
        <input type="checkbox" class="checkbox checkbox-primary w-4 h-4 rounded border-gray-300 text-primary focus:ring-primary" data-submission-id="<%= submission.id %>" />
      </div>
    <% end %>

    <div class="min-w-0 flex-1">
      <% if local_assigns[:with_template] %>
        <% template = submission.template %>
        <div class="flex items-center gap-2 mb-1">
          <%= link_to template ? template_path(template) : submission_path(submission), class: "text-sm font-medium text-gray-900 hover:text-primary truncate block" do %>
            <%= submission.name || template.name %>
          <% end %>
        </div>
      <% end %>
      
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-gray-500">
        <span class="flex items-center gap-1">
          <%= svg_icon('user', class: 'w-3 h-3') %>
          <%= (submission.created_by_user || submission.template&.author)&.full_name || (submission.created_by_user || submission.template&.author)&.email %>
        </span>
        <span class="flex items-center gap-1">
          <%= svg_icon('calendar', class: 'w-3 h-3') %>
          <%= l(submission.created_at.in_time_zone(current_account.timezone), format: :short, locale: current_account.locale) %>
        </span>
      </div>
    </div>
  </div>

  <div class="flex flex-col md:flex-row md:items-center gap-3 flex-shrink-0">
    <% submitters = (submission.template_submitters || submission.template.submitters).filter_map { |item| submission.submitters.find { |e| e.uuid == item['uuid'] } } %>
    <% is_submission_completed = submitters.all?(&:completed_at?) && submitters.size.positive? %>

    <!-- Status Badges -->
    <div class="flex flex-col gap-2 min-w-[140px]">
      <% if submitters.size == 1 %>
        <% submitter = submitters.first %>
        <% if submission.expired? && !submitter.completed_at? && !submitter.declined_at? %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800 w-fit">
            <%= t('expired') %>
          </span>
        <% else %>
          <div class="flex items-center gap-2">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= status_badges[submitter.status] || 'bg-gray-100 text-gray-800' %>">
              <%= t(submitter.status) %>
            </span>
            <span class="text-xs text-gray-500 truncate max-w-[150px]" title="<%= submitter.email %>">
               <%= submitter.name || submitter.email %>
            </span>
          </div>
        <% end %>
      <% else %>
        <!-- Multiple submitters summary -->
         <% if is_submission_completed %>
           <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 w-fit">
             <%= t('completed') %>
           </span>
         <% elsif submission.expired? %>
           <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800 w-fit">
             <%= t('expired') %>
           </span>
         <% else %>
           <% # Show simplified status for multiple %>
           <div class="flex -space-x-1 overflow-hidden">
             <% submitters.each do |s| %>
               <div class="tooltip" data-tip="<%= s.email %>: <%= t(s.status) %>">
                 <span class="inline-block w-2.5 h-2.5 rounded-full ring-1 ring-white <%= s.completed_at? ? 'bg-green-400' : 'bg-gray-300' %>"></span>
               </div>
             <% end %>
           </div>
           <span class="text-xs text-gray-500"><%= submitters.count(&:completed_at?) %>/<%= submitters.size %> signed</span>
         <% end %>
      <% end %>
    </div>

    <!-- Actions -->
    <div class="flex items-center gap-2">
      <% if submitters.size == 1 && !submission.expired? %>
        <% submitter = submitters.first %>
        <% if !submitter.completed_at? && !submitter.declined_at? %>
           <% if current_user.email == submitter.email %>
             <a href="<%= submit_form_url(slug: submitter.slug) %>" target="_blank" class="btn btn-sm btn-primary">
               <%= t('sign_now') %>
             </a>
           <% else %>
             <%= render 'shared/clipboard_copy', text: submit_form_url(slug: submitter.slug, host: form_link_host), class: 'btn btn-sm btn-ghost text-gray-600 hover:text-primary', icon_class: 'w-4 h-4', copy_title: t('copy_link'), copy_title_md: t('copy_link'), copied_title_md: t('copied') %>
           <% end %>
        <% end %>
      <% end %>

      <% if is_submission_completed %>
        <% latest_slug = submitters.max_by(&:completed_at)&.slug %>
        <download-button data-src="<%= submitter_download_index_path(latest_slug) %>" class="btn btn-sm btn-ghost text-gray-600 hover:text-primary">
          <%= svg_icon('download', class: 'w-4 h-4') %>
        </download-button>
      <% end %>

      <%= link_to submission_path(submission), class: "btn btn-sm btn-ghost text-gray-600 hover:text-primary" do %>
        <%= t('view') %>
      <% end %>

      <% if !submission.archived_at? && !submission.template&.archived_at? %>
        <div class="dropdown dropdown-end">
           <label tabindex="0" class="btn btn-sm btn-ghost btn-square text-gray-400 hover:text-gray-600">
             <%= svg_icon('dots_vertical', class: 'w-4 h-4') %>
           </label>
           <ul tabindex="0" class="dropdown-content menu p-2 shadow bg-base-100 rounded-box w-52 z-[1]">
             <li>
               <%= button_to submission_path(submission), method: :delete, class: "text-red-600 hover:bg-red-50" do %>
                 <%= svg_icon('archive', class: 'w-4 h-4 mr-2') %>
                 <%= t('archive') %>
               <% end %>
             </li>
             <% if local_assigns[:archived] && can?(:destroy, submission) %>
                <li>
                  <%= button_to submission_path(submission, permanently: true), method: :delete, data: { turbo_confirm: t('are_you_sure') }, class: "text-red-600 hover:bg-red-50" do %>
                    <%= svg_icon('trash', class: 'w-4 h-4 mr-2') %>
                    <%= t('remove') %>
                  <% end %>
                </li>
             <% end %>
           </ul>
        </div>
      <% end %>
    </div>
  </div>
</div>
