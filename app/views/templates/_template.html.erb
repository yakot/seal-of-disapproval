<div class="relative group flex flex-col h-full bg-base-100 rounded-xl border border-base-300 hover:shadow-lg hover:border-primary transition-all duration-200">
  <a href="<%= template_path(template) %>" class="flex-grow p-5 flex flex-col" data-targets="dashboard-dropzone.templateCards">
    <div class="flex items-start justify-between mb-4">
      <div class="p-2 bg-primary/10 rounded-lg">
        <%= svg_icon('file_text', class: 'w-6 h-6 text-primary') %>
      </div>
      <% if template.template_accesses.present? %>
        <%= svg_icon('lock', class: 'w-4 h-4 text-base-content/40') %>
      <% end %>
    </div>
    
    <h3 class="font-bold text-lg leading-tight mb-2 line-clamp-2" title="<%= template.name %>">
      <% template.name.split(/(_)/).each do |item| %><%= item %><wbr><% end %>
    </h3>

    <div class="mt-auto space-y-2">
      <div class="flex items-center text-xs text-base-content/60">
        <%= svg_icon('user', class: 'w-3 h-3 mr-1.5') %>
        <span class="truncate"><%= template.author.full_name.presence || template.author.email.to_s.sub(/\+\w+@/, '@') %></span>
        <% if template.account_id != current_account.id %>
          <span class="ml-2 badge badge-neutral badge-outline badge-sm text-[10px] uppercase"><%= t('shared') %></span>
        <% end %>
      </div>
      <div class="flex items-center text-xs text-base-content/60">
        <%= svg_icon('calendar', class: 'w-3 h-3 mr-1.5') %>
        <span><%= l(template.created_at.in_time_zone(current_account.timezone), format: :short, locale: current_account.locale) %></span>
        <% if template.archived_at? %>
          <span class="ml-2 flex items-center space-x-1">
            <%= svg_icon('folder', class: 'w-3 h-3') %>
            <span class="truncate max-w-[100px]"><%= template.folder.full_name %></span>
          </span>
        <% end %>
      </div>
    </div>
  </a>

  <div class="px-4 py-3 border-t border-base-200 flex justify-end gap-1 bg-base-50/50 rounded-b-xl" data-targets="dashboard-dropzone.hiddenOnDrag">
      <% if can?(:update, template) && !template.archived_at? && template.account_id == current_account.id %>
        <span class="tooltip tooltip-left" data-tip="<%= t('move') %>">
          <a href="<%= edit_template_folder_path(template.id) %>" data-turbo-frame="modal" class="btn btn-ghost btn-xs btn-square">
            <%= svg_icon('folder_share', class: 'w-4 h-4') %>
          </a>
        </span>
      <% end %>
      <% if template.archived_at? && can?(:update, template) %>
        <span class="tooltip tooltip-left" data-tip="<%= t('restore') %>">
          <%= button_to template_restore_index_path(template), class: 'btn btn-ghost btn-xs btn-square' do %>
            <%= svg_icon('rotate', class: 'w-4 h-4 enabled') %>
            <%= svg_icon('loader', class: 'w-4 h-4 animate-spin disabled') %>
          <% end %>
        </span>
      <% elsif can?(:update, template) %>
        <span class="tooltip tooltip-left" data-tip="<%= t('edit') %>">
          <a href="<%= edit_template_path(template) %>" class="btn btn-ghost btn-xs btn-square">
            <%= svg_icon('pencil', class: 'w-4 h-4') %>
          </a>
        </span>
      <% end %>
      <% if can?(:create, template) %>
        <span class="tooltip tooltip-left" data-tip="<%= t('clone') %>">
          <a href="<%= new_template_clone_path(template) %>" data-turbo-frame="modal" class="btn btn-ghost btn-xs btn-square">
            <%= svg_icon('copy', class: 'w-4 h-4') %>
          </a>
        </span>
      <% end %>
      <% if can?(:destroy, template) %>
        <span class="tooltip tooltip-left" data-tip="<%= template.archived_at? ? t('delete') : t('archive') %>">
          <%= button_to template_path(template), data: template.archived_at? ? { turbo_confirm: t('template_deletion_is_irreversible_and_will_permanently_remove_all_associated_signed_documents_with_it_are_you_sure_') } : {}, params: { permanently: template.archived_at? }.compact_blank, method: :delete, class: 'btn btn-ghost btn-xs btn-square text-error', aria_label: t('restore') do %>
            <%= svg_icon(template.archived_at? ? 'trash' : 'archive', class: 'w-4 h-4 enabled') %>
            <%= svg_icon('loader', class: 'w-4 h-4 animate-spin disabled') %>
          <% end %>
        </span>
      <% end %>
  </div>
</div>
